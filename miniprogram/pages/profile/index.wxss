.container {
  padding: 30rpx;
  background-color: #f0f2ff;
  min-height: 100vh;
  padding-bottom: 120rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.header {
  background: transparent;
  padding: 40rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-bottom: none;
  flex: 1;
}

.avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff;
  margin-bottom: 20rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 20rpx rgba(124, 77, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 20rpx rgba(124, 77, 255, 0.15);
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.page-title {
  font-size: 28rpx;
  color: #7c4dff;
  font-weight: 600;
  margin-top: 10rpx;
  background: rgba(124, 77, 255, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

.login-btn {
  margin-top: 80rpx;
  background: linear-gradient(135deg, #7c4dff 0%, #6200ea 100%) !important;
  color: #fff !important;
  border-radius: 50rpx;
  padding: 0 80rpx;
  font-weight: bold;
  box-shadow: 0 10rpx 20rpx rgba(124, 77, 255, 0.3);
  border: none;
}

.section {
  background: transparent;
  margin: 0;
  padding: 0;
  box-shadow: none;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  margin: 40rpx 0 24rpx 0;
  color: #7c4dff; /* Purple Title */
  padding-left: 0;
  border-left: none;
}

/* Habit Card Style List Items */
checkbox-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(124, 77, 255, 0.05);
  transition: all 0.2s;
  width: 100%;
  box-sizing: border-box;
}

.card-item:active {
  transform: scale(0.98);
}

.card-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  background: #f5f3ff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  color: #7c4dff;
}

.card-info {
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.card-tag {
  font-size: 24rpx;
  color: #7c4dff;
  background: #f0f2ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

/* Custom Checkbox Style */
.checkbox-circle {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  border: 4rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.checkbox-circle.checked {
  background: #7c4dff;
  border-color: #7c4dff;
  box-shadow: 0 4rpx 10rpx rgba(124, 77, 255, 0.3);
}

.check-icon {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* Hide default checkbox */
checkbox {
  display: none;
}

/* Input Section */
.input-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(124, 77, 255, 0.05);
  display: flex;
  align-items: center;
}

.input-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff9c4; /* Soft Yellow for variety */
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input {
  flex: 1;
  background: transparent;
  padding: 10rpx;
  font-size: 30rpx;
  border: none;
  height: 60rpx;
  color: #333;
}

.save-btn {
  margin-top: 60rpx;
  width: 100%;
  background: linear-gradient(135deg, #7c4dff 0%, #6200ea 100%) !important;
  color: #fff !important;
  border-radius: 40rpx;
  font-weight: bold;
  padding: 24rpx 0;
  box-shadow: 0 10rpx 20rpx rgba(124, 77, 255, 0.3);
  font-size: 32rpx;
}

.logout {
  text-align: center;
  color: #999;
  padding: 40rpx;
  font-size: 26rpx;
}
