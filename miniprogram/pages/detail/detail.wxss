.container {
  padding: 0;
  background-color: #fff;
  min-height: 100vh;
}
.backdrop {
  width: 100%;
  display: block;
}
.content {
  padding: 30rpx;
}
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}
.tagline {
  font-style: italic;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  display: block;
}
.meta {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}
.date {
  background: #eee;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #555;
  margin-right: 20rpx;
}
.rating {
  font-weight: bold;
  color: #ff9800;
  font-size: 32rpx;
}
.section {
  margin-bottom: 30rpx;
}
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  display: block;
  border-left: 8rpx solid #333;
  padding-left: 16rpx;
}
.overview {
  font-size: 30rpx;
  line-height: 1.6;
  color: #444;
  display: block;
}
.loading {
  text-align: center;
  padding: 50rpx;
  color: #999;
}
