<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索电影..." bindconfirm="onSearch" confirm-type="search" />
  </view>
  <scroll-view scroll-y class="movie-list">
    <view class="movie-item" wx:for="{{movies}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="poster-thumb" src="{{item.poster_path ? imageBaseUrl + item.poster_path : ''}}" mode="aspectFill"></image>
      <view class="info">
        <text class="title">{{item.title}}</text>
        <text class="year">{{item.release_date}}</text>
      </view>
    </view>
    <view wx:if="{{movies.length === 0 && searched}}" class="no-results">
      未找到相关电影
    </view>
  </scroll-view>
</view>
