/**index.wxss**/
/* Container */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
  position: relative;
  background-color: #1a1a1a; /* Dark fallback */
  padding: 0; /* Remove padding from root container */
}

/* Content Wrapper */
.content-wrapper {
  width: 100%;
  padding: 0; /* Full width */
  margin-top: 0; /* Flush with nav bar area */
  box-sizing: border-box;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1; /* Fill remaining vertical space */
}

/* Background Layer */
.background-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.background-image {
  width: 100%;
  height: 100%;
  filter: blur(40px) brightness(0.6);
  transform: scale(1.1); /* Prevent blur edges */
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.1),
    rgba(0, 0, 0, 0.8)
  );
}

/* Nav Extension Fill (Fills gap with nav color) */
.nav-extension-fill {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh; /* Full viewport height for gradient background */
  background: linear-gradient(
    180deg,
    rgba(124, 77, 255, 0.85) 0%,
    rgba(124, 77, 255, 0.3) 40%,
    transparent 70%
  ); /* Smooth gradient transition */
  z-index: 0; /* Behind content but above background */
  backdrop-filter: blur(20px);
  pointer-events: none; /* Allow clicks to pass through */
}

/* Override nav for this page to blend with background */
.custom-nav {
  background: rgba(124, 77, 255, 0.85) !important;
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: none !important; /* Remove shadow to blend with fill */
}

/* Loading State */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  width: 100%;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #7c4dff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  font-weight: 500;
}

/* Error State */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
  width: 100%;
  text-align: center;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.error-text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 30rpx;
  margin-bottom: 50rpx;
  line-height: 1.6;
}

.retry-btn {
  background: linear-gradient(135deg, #7c4dff, #651fff);
  color: #fff;
  border-radius: 30rpx;
  padding: 0 60rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 32rpx rgba(101, 31, 255, 0.3);
}

.retry-btn:active {
  transform: scale(0.98);
}

/* Glass Card */
.glass-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 40rpx 40rpx 0 0; /* Rounded top, flush bottom */
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(255, 255, 255, 0.6);
  border-bottom: none; /* No border at bottom */
  display: flex;
  flex-direction: column;
  margin-bottom: 0; /* No bottom margin */
  position: relative;
  z-index: 1;
  transform: translateY(0);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  min-height: 60vh; /* Ensure card has minimum height */
}

.glass-card:active {
  transform: scale(0.99);
}

/* Poster Wrapper */
.poster-wrapper {
  width: 100%;
  height: 800rpx;
  position: relative;
  background: linear-gradient(135deg, #2a2a2a 0%, #1a1a1a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.poster {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Poster placeholder when image fails */
.poster-wrapper::before {
  content: "🎬";
  font-size: 120rpx;
  opacity: 0.3;
  position: absolute;
  z-index: 0;
}

.poster[src=""], .poster[poster-error="true"] {
  opacity: 0;
}

/* Info Section */
.info {
  padding: 50rpx 40rpx;
  display: flex;
  flex-direction: column;
}

.header {
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.title {
  font-size: 52rpx;
  font-weight: 900;
  color: #1a1a1a;
  line-height: 1.2;
  margin-bottom: 16rpx;
  letter-spacing: -1rpx;
}

.tagline {
  font-size: 28rpx;
  color: #666;
  font-style: italic;
  font-weight: 500;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

/* Tags */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tag {
  font-size: 22rpx;
  color: #651fff;
  background: rgba(101, 31, 255, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

/* Meta Row */
.meta-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  gap: 24rpx;
}

.rating-box {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.rating-star {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.rating-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #333;
}

.meta-divider {
  color: #ddd;
  font-weight: 300;
  font-size: 24rpx;
}

.release-date {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* Overview */
.overview {
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
  text-align: justify;
  margin-bottom: 50rpx;
  display: -webkit-box;
  -webkit-line-clamp: 8;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 400;
}

/* Button */
.refresh-btn {
  background: linear-gradient(135deg, #7c4dff, #651fff);
  color: #fff;
  border-radius: 30rpx;
  padding: 0;
  width: 100%;
  height: 110rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 20rpx 40rpx rgba(101, 31, 255, 0.25);
  transition: all 0.2s;
  border: none;
}

.refresh-btn:active {
  transform: scale(0.98);
  box-shadow: 0 10rpx 20rpx rgba(101, 31, 255, 0.2);
}

.btn-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}
