/**index.wxss**/

/* ============================================
   基础容器 - 沉浸式布局
   ============================================ */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 50%, #1a1a2e 100%);
  position: relative;
  overflow: hidden;
}

/* ============================================
   背景模糊层 - 电影海报氛围感
   ============================================ */
.background-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  overflow: hidden;
}

.background-image {
  width: 100%;
  height: 100%;
  filter: blur(60px) brightness(0.4);
  transform: scale(1.15);
  opacity: 0.6;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(102, 126, 234, 0.4) 0%,
    rgba(118, 75, 162, 0.5) 50%,
    rgba(26, 26, 46, 0.8) 100%
  );
}

/* ============================================
   导航栏样式
   ============================================ */
.custom-nav {
  position: relative;
  z-index: 10;
  background: linear-gradient(180deg, rgba(102, 126, 234, 0.95), rgba(102, 126, 234, 0.8));
  backdrop-filter: blur(30px);
  -webkit-backdrop-filter: blur(30px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.15);
}

.custom-nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* ============================================
   内容区域
   ============================================ */
.content-wrapper {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

/* ============================================
   加载状态
   ============================================ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* ============================================
   错误状态
   ============================================ */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  padding-left: 60rpx;
  padding-right: 60rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.8;
}

.error-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
  text-align: center;
  line-height: 1.7;
  margin-bottom: 48rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
  color: #667eea;
  border-radius: 100rpx;
  padding: 0 56rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.3);
  border: none;
}

.retry-btn:active {
  transform: scale(0.96);
}

/* ============================================
   电影卡片 - 毛玻璃效果
   ============================================ */
.glass-card {
  width: 100%;
  max-width: 720rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    0 0 0 1px rgba(255, 255, 255, 0.2) inset;
  border: 1px solid rgba(255, 255, 255, 0.3);
  animation: cardFloat 0.6s ease-out;
}

@keyframes cardFloat {
  from {
    opacity: 0;
    transform: translateY(40rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.glass-card:active {
  transform: scale(0.99);
  transition: transform 0.2s;
}

/* ============================================
   海报区域 - 影院级展示
   ============================================ */
.poster-wrapper {
  position: relative;
  width: 100%;
  height: 700rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
}

.poster {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 海报渐变遮罩 - 平滑过渡到内容区 */
.poster-gradient-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(
    to top,
    rgba(255, 255, 255, 1) 0%,
    rgba(255, 255, 255, 0.7) 30%,
    transparent 100%
  );
  pointer-events: none;
}

/* 海报失败占位符 */
.poster-wrapper::before {
  content: "🎬";
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 140rpx;
  opacity: 0.2;
  z-index: 0;
}

.poster[src=""],
.poster[poster-error="true"] {
  opacity: 0;
}

/* ============================================
   信息内容区
   ============================================ */
.info {
  padding: 32rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* 标题区域 */
.content-header {
  margin-bottom: 24rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
  line-height: 1.35;
  letter-spacing: -0.5rpx;
  text-align: center;
  margin-bottom: 12rpx;
}

.tagline {
  display: block;
  font-size: 26rpx;
  color: #888;
  font-style: italic;
  font-weight: 400;
  line-height: 1.5;
}

/* ============================================
   类型标签 - 多彩胶囊
   ============================================ */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.tag {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* ============================================
   评分与元数据 - 数据中心风格
   ============================================ */
.meta-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.rating-box {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.rating-star {
  font-size: 32rpx;
}

.rating-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #1a1a2e;
  font-variant-numeric: tabular-nums;
}

.rating-max {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.meta-divider {
  color: #ddd;
  font-weight: 300;
  font-size: 28rpx;
}

.release-date {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}

.release-date::before {
  content: "📅";
  font-size: 28rpx;
}

/* ============================================
   剧情简介 - 阅读优化
   ============================================ */
.overview-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #667eea;
  text-transform: uppercase;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}

.overview {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
  text-align: justify;
  margin-bottom: 32rpx;
  display: -webkit-box;
  -webkit-line-clamp: 6;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 400;
}

/* ============================================
   换一换按钮 - 主要交互
   ============================================ */
.refresh-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
  border: none;
}

.refresh-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

.btn-icon {
  margin-right: 10rpx;
  font-size: 34rpx;
}
