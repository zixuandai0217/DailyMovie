/* Global Container */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f0f2ff;
  position: relative;
  overflow: hidden;
}

/* --- Welcome Mode (Initial State) --- */
.container.welcome-mode {
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

.welcome-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 60rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 40rpx;
  animation: pulse 3s infinite ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    filter: drop-shadow(0 4rpx 8rpx rgba(124, 77, 255, 0.2));
  }
  50% {
    transform: scale(1.05);
    filter: drop-shadow(0 8rpx 20rpx rgba(124, 77, 255, 0.4));
  }
  100% {
    transform: scale(1);
    filter: drop-shadow(0 4rpx 8rpx rgba(124, 77, 255, 0.2));
  }
}

.sub-greeting-container {
  font-size: 52rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 20rpx;
}

.sub-greeting-container {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
}

.sub-greeting {
  font-size: 32rpx;
  color: #666;
  text-align: center;
}

.cursor {
  width: 16rpx;
  height: 16rpx;
  background-color: #7c4dff;
  border-radius: 50%;
  margin-left: 8rpx;
}

/* Logo Animation */
.logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 40rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(124, 77, 255, 0.2));
  animation: pulse 3s infinite ease-in-out;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    filter: drop-shadow(0 4rpx 8rpx rgba(124, 77, 255, 0.2));
  }
  50% {
    transform: scale(1.05);
    filter: drop-shadow(0 8rpx 20rpx rgba(124, 77, 255, 0.4));
  }
  100% {
    transform: scale(1);
    filter: drop-shadow(0 4rpx 8rpx rgba(124, 77, 255, 0.2));
  }
}

/* --- Chat Mode (Results State) --- */
.container.chat-mode {
  justify-content: flex-start;
}

.result-list {
  flex: 1;
  padding: 30rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* --- Input Wrapper Styling --- */
.input-wrapper {
  width: 100%;
  box-sizing: border-box;
  transition: all 0.3s ease;
  z-index: 10;
}

.container.chat-mode .input-wrapper {
  position: absolute;
  bottom: 0;
  padding: 20rpx;
  background: rgba(240, 242, 255, 0.9);
  backdrop-filter: blur(10px);
}

.input-box {
  background: #fff;
  border-radius: 50rpx;
  padding: 10rpx 20rpx 10rpx 40rpx;
  display: flex;
  align-items: center;
  height: 100rpx;
  box-shadow: 0 8rpx 24rpx rgba(124, 77, 255, 0.15);
  border: 2rpx solid transparent;
}

.input-box:focus-within {
  border-color: #7c4dff;
}

.prompt-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #333;
  padding: 0 20rpx;
}

.send-btn-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7c4dff, #448aff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(124, 77, 255, 0.3);
}

.loading {
  text-align: center;
  color: #7c4dff;
  padding: 40rpx;
  font-weight: bold;
}

.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
  color: #7c4dff;
  font-weight: bold;
  font-size: 36rpx;
}

/* Chat Mode Input: Fixed Bottom, Flat */
.chat-mode .input-wrapper {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
}

.chat-mode .input-box {
  background: #f0f0f0;
  border-radius: 40rpx;
  padding: 10rpx 20rpx;
  display: flex;
  align-items: center;
  height: 80rpx;
}

.chat-mode .send-btn-icon {
  width: 60rpx;
  height: 60rpx;
}

/* --- Movie Card Styling (Professional & Centered) --- */
.movie-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.movie-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.poster {
  width: 160rpx;
  height: 240rpx;
  border-radius: 16rpx;
  background: #f0f0f0;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.info {
  margin-left: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  overflow: hidden;
  min-height: 240rpx;
}

.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.2;
}

.year {
  font-size: 22rpx;
  color: #7c4dff;
  background: rgba(124, 77, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  display: inline-block;
  align-self: flex-start;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.overview {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: justify;
}
